{
  "name": "plantiteatit-api",
  "version": "1.0.0",
  "description": "Backend API for PlantItEatIt. Node/Express on Render, PostgreSQL. GPS-filtered plant species from USDA PLANTS database.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "ingest": "node scripts/ingest-usda.js",
    "ingest:arizona": "node scripts/ingest-arizona.js",
    "images": "node scripts/resolve-images.js",
    "seed:food": "node scripts/seed-food-plants.js",
    "db:schema": "psql $DATABASE_URL -f db/schema.sql"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}